<script>
  // OS detection
  function detectOS(): 'unix' | 'win' {
    const ua = navigator.userAgent || '';
    const platform = (navigator as any).userAgentData?.platform || navigator.platform || '';
    if (/win/i.test(platform) || /windows/i.test(ua)) return 'win';
    return 'unix';
  }

  function setOS(os: 'unix' | 'win') {
    // Update all tab groups (hero + quickstart + final CTA)
    document.querySelectorAll('.os-tab, .code-os-tab').forEach(tab => {
      const tabOS = (tab as HTMLElement).dataset.os;
      tab.setAttribute('aria-selected', tabOS === os ? 'true' : 'false');
    });

    // Show/hide command blocks
    document.querySelectorAll('.os-cmd--unix').forEach(el => {
      (el as HTMLElement).style.display = os === 'unix' ? '' : 'none';
    });
    document.querySelectorAll('.os-cmd--win').forEach(el => {
      (el as HTMLElement).style.display = os === 'win' ? '' : 'none';
    });

    // Update copy button data-copy attributes
    document.querySelectorAll('.copy-btn[data-copy-unix]').forEach(btn => {
      const key = os === 'win' ? 'data-copy-win' : 'data-copy-unix';
      btn.setAttribute('data-copy', btn.getAttribute(key) || '');
    });
  }

  // Initialize OS detection
  setOS(detectOS());

  // Tab click handlers
  document.querySelectorAll('.os-tab, .code-os-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      const os = (tab as HTMLElement).dataset.os as 'unix' | 'win';
      if (os) setOS(os);
    });
  });

  // Copy button functionality
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const text = btn.getAttribute('data-copy');
      if (!text) return;
      await navigator.clipboard.writeText(text);
      btn.classList.add('copied');
      setTimeout(() => btn.classList.remove('copied'), 2000);
    });
  });

  // Nav scroll effect
  const nav = document.querySelector('.top-nav');
  if (nav) {
    window.addEventListener('scroll', () => {
      nav.classList.toggle('top-nav--scrolled', window.scrollY > 20);
    }, { passive: true });
  }
</script>

<style>
  /* ===== SKIP LINK ===== */
  .skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    z-index: 200;
    padding: 0.75rem 1.5rem;
    background: var(--color-accent);
    color: var(--color-bg-deep);
    font-weight: 600;
    border-radius: 0 0 8px 8px;
    transition: top 0.2s;
  }

  .skip-link:focus {
    top: 0;
    color: var(--color-bg-deep);
  }

  /* ===== TOP NAV ===== */
  .top-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 0.75rem 1.5rem;
    background: rgba(10, 10, 15, 0.8);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid transparent;
    transition: border-color 0.3s;
  }

  .top-nav--scrolled {
    border-bottom-color: var(--color-border);
  }

  .top-nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .nav-brand {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.15rem;
    color: var(--color-text);
    letter-spacing: -0.01em;
  }

  .nav-brand:hover {
    color: var(--color-accent-light);
  }

  .nav-links {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }

  .nav-link {
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--color-text-muted);
    transition: color 0.2s;
  }

  .nav-link:hover {
    color: var(--color-text);
  }

  .nav-link--primary {
    color: var(--color-accent);
  }

  .nav-link--primary:hover {
    color: var(--color-accent-light);
  }

  /* ===== HERO ===== */
  .hero {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: auto;
    padding: 7rem 1.5rem 4rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: -30%;
    left: 50%;
    transform: translateX(-50%);
    width: 1000px;
    height: 1000px;
    background: radial-gradient(
      ellipse at center,
      rgba(34, 211, 238, 0.18) 0%,
      rgba(34, 211, 238, 0.08) 30%,
      rgba(34, 211, 238, 0.03) 50%,
      transparent 70%
    );
    pointer-events: none;
  }

  .hero::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      var(--color-border) 50%,
      transparent 100%
    );
  }

  .hero-inner {
    max-width: var(--max-width);
    position: relative;
  }

  .hero-badge {
    display: inline-block;
    padding: 0.35rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 100px;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
    margin-bottom: 2rem;
    animation: fadeInUp 0.6s ease-out 0s both;
  }

  .hero-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.75rem, 5vw, 3.5rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
    background: linear-gradient(160deg, #fff 0%, #e0f7fa 50%, var(--color-accent-light) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: fadeInUp 0.6s ease-out 0.1s both;
  }

  .hero-tagline {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: clamp(1.05rem, 2vw, 1.2rem);
    color: var(--color-text-muted);
    max-width: 520px;
    margin: 0 auto 2.5rem;
    line-height: 1.7;
    animation: fadeInUp 0.6s ease-out 0.2s both;
  }

  /* ===== OS TABS (hero + final CTA) ===== */
  .hero-install-wrap {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 2rem;
    animation: fadeInUp 0.6s ease-out 0.3s both;
    max-width: 100%;
  }

  .os-tabs {
    display: inline-flex;
    gap: 0;
    margin-bottom: 0.5rem;
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 3px;
  }

  .os-tab {
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 500;
    padding: 0.35rem 0.85rem;
    border: none;
    border-radius: 6px;
    background: transparent;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all 0.2s;
    white-space: nowrap;
  }

  .os-tab[aria-selected="true"] {
    background: var(--color-bg-elevated);
    color: var(--color-accent);
  }

  .os-tab:hover:not([aria-selected="true"]) {
    color: var(--color-text);
  }

  /* ===== OS TABS (quickstart code window) ===== */
  .code-os-tabs {
    display: inline-flex;
    gap: 0;
    margin-left: auto;
    margin-right: 0.5rem;
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 2px;
  }

  .code-os-tab {
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 500;
    padding: 0.25rem 0.65rem;
    border: none;
    border-radius: 4px;
    background: transparent;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all 0.2s;
    white-space: nowrap;
  }

  .code-os-tab[aria-selected="true"] {
    background: var(--color-bg-surface);
    color: var(--color-accent);
  }

  .code-os-tab:hover:not([aria-selected="true"]) {
    color: var(--color-text);
  }

  .hero-install {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 0.75rem 4rem 0.75rem 1.25rem;
    position: relative;
    min-width: min(100%, 660px);
    max-width: 100%;
    overflow-x: auto;
  }

  .hero-cmd {
    font-family: var(--font-mono);
    font-size: 0.88rem;
    color: var(--color-text);
    white-space: nowrap;
  }

  .hero-copy {
    position: absolute;
    right: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 2rem;
    animation: fadeInUp 0.6s ease-out 0.4s both;
  }

  .hero-social-proof {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    animation: fadeInUp 0.6s ease-out 0.5s both;
  }

  .github-stars {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 0.85rem;
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: 100px;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--color-text);
    transition: all 0.2s;
  }

  .github-stars:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .github-stars svg {
    flex-shrink: 0;
  }

  .social-sep {
    color: var(--color-border);
  }

  .social-label {
    font-size: 0.82rem;
    color: var(--color-text-muted);
  }

  .hero-break {
    display: block;
  }

  /* ===== BUTTONS ===== */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.75rem;
    border-radius: 8px;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 0.2s;
    cursor: pointer;
    border: none;
  }

  .btn-primary {
    background: var(--color-accent);
    color: var(--color-bg-deep);
  }

  .btn-primary:hover {
    background: var(--color-accent-light);
    color: var(--color-bg-deep);
    transform: translateY(-1px);
    box-shadow: 0 4px 20px rgba(34, 211, 238, 0.3);
  }

  .btn-ghost {
    background: transparent;
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }

  .btn-ghost:hover {
    border-color: var(--color-text-muted);
    color: var(--color-text);
    transform: translateY(-1px);
  }

  /* ===== SECTION COMMON ===== */
  .section-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.5rem, 3vw, 2rem);
    text-align: center;
    margin-bottom: 1rem;
    color: var(--color-text);
  }

  .section-subtitle {
    text-align: center;
    color: var(--color-text-muted);
    font-size: 1.05rem;
    max-width: 540px;
    margin: 0 auto 2.5rem;
    line-height: 1.6;
  }

  .section-title + .section-subtitle {
    margin-top: -0.25rem;
  }

  /* ===== 2. FEATURES ===== */
  .features {
    padding: 6rem 1.5rem;
    max-width: var(--max-width);
    margin: 0 auto;
    text-align: center;
    position: relative;
  }

  /* no divider — how-steps bg band provides the visual break */

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    text-align: left;
  }

  .feature-card {
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 2rem;
    transition: all 0.25s;
  }

  .feature-card:hover {
    transform: translateY(-2px);
    border-color: rgba(34, 211, 238, 0.2);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);
  }

  .feature-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 8px;
    background: rgba(34, 211, 238, 0.1);
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .feature-card h3 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
    color: var(--color-text);
  }

  .feature-card p {
    color: var(--color-text-muted);
    font-size: 0.88rem;
    line-height: 1.6;
  }

  .feature-card code {
    color: var(--color-accent);
    font-size: 0.85em;
  }

  /* ===== 3. HOW STEPS ===== */
  .how-steps {
    padding: 6rem 1.5rem;
    text-align: center;
    position: relative;
    background: var(--color-bg-surface);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    text-align: left;
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .step-card {
    background: transparent;
    border: none;
    border-radius: 0;
    padding: 1.5rem 0;
    position: relative;
  }

  .step-card + .step-card {
    border-left: 1px solid var(--color-border);
    padding-left: 2rem;
  }

  .step-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 50%;
    background: var(--color-accent);
    color: var(--color-bg-deep);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }

  .step-card h3 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
    color: var(--color-text);
  }

  .step-card p {
    color: var(--color-text-muted);
    font-size: 0.88rem;
    line-height: 1.6;
  }

  .step-card code {
    color: var(--color-accent);
    font-size: 0.85em;
  }

  /* ===== 4. QUICK START ===== */
  .quickstart {
    padding: 6rem 1.5rem;
    max-width: 680px;
    margin: 0 auto;
    position: relative;
  }

  .quickstart::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 60%;
    max-width: 400px;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, var(--color-border) 50%, transparent 100%);
  }

  .cli-output {
    margin-top: 1.5rem;
  }

  .code-window {
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
  }

  .code-tabs {
    display: flex;
    align-items: center;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg-surface);
    padding: 0.4rem 0;
  }

  .window-dots {
    display: flex;
    gap: 6px;
    padding: 0 1rem;
  }

  .window-dots span {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--color-border);
  }

  .window-dots span:first-child {
    background: #ff5f57;
  }

  .window-dots span:nth-child(2) {
    background: #febc2e;
  }

  .window-dots span:nth-child(3) {
    background: #28c840;
  }

  .code-block {
    position: relative;
    padding: 1.5rem;
  }

  .code-block:has(.copy-btn) {
    padding-right: 4.5rem;
  }

  .code-block pre {
    margin: 0;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .code-block code {
    font-family: var(--font-mono);
    font-size: 0.88rem;
    line-height: 1.8;
    color: var(--color-text);
    word-break: break-all;
    overflow-wrap: break-word;
  }

  .code-block .c {
    color: var(--color-text-muted);
  }

  .code-block .p {
    color: var(--color-green);
    user-select: none;
  }

  .code-block .f {
    color: var(--color-accent);
  }

  .code-block .s {
    color: var(--color-green);
  }

  .resolution-tab {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--color-accent);
    padding: 0.7rem 1.25rem;
  }

  .copy-btn {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    padding: 0.4rem;
    border-radius: 6px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
  }

  .copy-btn:hover {
    color: var(--color-text);
    border-color: var(--color-text-muted);
  }

  .copy-btn .check-icon {
    display: none;
  }

  .copy-btn.copied .check-icon {
    display: block;
    color: var(--color-green);
  }

  .copy-btn.copied svg:first-child {
    display: none;
  }

  /* ===== 5. ARCHITECTURE ===== */
  .architecture {
    padding: 6rem 1.5rem;
    max-width: var(--max-width);
    margin: 0 auto;
    text-align: center;
    position: relative;
  }

  /* no divider — arch items' top-borders provide visual structure */

  .arch-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem 3rem;
    text-align: left;
  }

  .arch-item {
    background: transparent;
    border: none;
    border-top: 2px solid var(--color-border);
    border-radius: 0;
    padding: 1.5rem 0 0;
    transition: border-color 0.25s;
  }

  .arch-item:hover {
    border-top-color: var(--color-accent);
  }

  .arch-item h3 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1rem;
    margin-bottom: 0.4rem;
    color: var(--color-text);
  }

  .arch-item p {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    line-height: 1.6;
  }

  .arch-item code {
    color: var(--color-accent);
    font-size: 0.85em;
  }

  /* ===== 6. ENTERPRISE ===== */
  .enterprise {
    padding: 6rem 1.5rem;
    max-width: var(--max-width);
    margin: 0 auto;
    text-align: center;
    position: relative;
  }

  .enterprise::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 60%;
    max-width: 400px;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, var(--color-border) 50%, transparent 100%);
  }

  .enterprise-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.75rem;
    text-align: left;
  }

  .enterprise-item {
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-accent-dark);
    border-radius: 4px 12px 12px 4px;
    padding: 1.75rem;
    transition: all 0.25s;
  }

  .enterprise-item:hover {
    border-left-color: var(--color-accent);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
  }

  .enterprise-item h3 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
    color: var(--color-text);
  }

  .enterprise-item p {
    color: var(--color-text-muted);
    font-size: 0.88rem;
    line-height: 1.6;
  }

  .enterprise-item code {
    color: var(--color-accent);
    font-size: 0.85em;
  }

  /* ===== 7. OPEN SOURCE ===== */
  .open-source {
    padding: 5rem 1.5rem;
    max-width: var(--max-width);
    margin: 0 auto;
    text-align: center;
    position: relative;
  }

  .open-source::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 60%;
    max-width: 400px;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, var(--color-border) 50%, transparent 100%);
  }

  .os-links {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }

  .hero-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    padding: 1.75rem 2.5rem;
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    transition: all 0.25s;
    min-width: 180px;
  }

  .hero-link:hover {
    transform: translateY(-2px);
    border-color: rgba(34, 211, 238, 0.3);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);
  }

  .hero-link svg {
    color: var(--color-accent);
    margin-bottom: 0.25rem;
  }

  .hero-link-label {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1rem;
    color: var(--color-text);
  }

  .hero-link-sub {
    font-size: 0.82rem;
    color: var(--color-text-muted);
  }

  .license-note {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  /* ===== 8. FINAL CTA ===== */
  .final-cta {
    padding: 5rem 1.5rem;
    max-width: var(--max-width);
    margin: 0 auto;
    text-align: center;
  }

  .builder-trigger {
    font-size: 1.05rem;
    color: var(--color-accent);
    font-weight: 500;
    margin-bottom: 1rem;
  }

  /* ===== FOOTER ===== */
  .footer {
    padding: 3rem 1.5rem 2rem;
    max-width: var(--max-width);
    margin: 0 auto;
    text-align: center;
    border-top: 1px solid var(--color-border);
  }

  .footer-links {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .footer-links a {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .footer-links a:hover {
    color: var(--color-accent);
  }

  .footer-sep {
    color: var(--color-border);
    font-size: 0.85rem;
  }

  .footer-brand {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
  }

  .footer-credit {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    opacity: 0.6;
  }

  /* ===== ANIMATIONS ===== */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    .features-grid,
    .steps-grid,
    .arch-grid,
    .enterprise-grid {
      grid-template-columns: 1fr;
    }

    .step-card + .step-card {
      border-left: none;
      border-top: 1px solid var(--color-border);
      padding-left: 0;
      padding-top: 1.5rem;
    }

    .nav-links {
      gap: 1rem;
    }

    .hero-break {
      display: none;
    }

    .hero-cmd {
      font-size: 0.78rem;
    }

    .os-links {
      flex-direction: column;
      align-items: center;
    }

    .hero-link {
      width: 100%;
      max-width: 300px;
    }
  }

  @media (max-width: 480px) {
